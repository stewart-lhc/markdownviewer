{
  "name": "markdownviewer",
  "version": "0.2.0",
  "description": "Open-source online Markdown viewer with live preview for README files, GitHub Flavored Markdown, Mermaid diagrams, KaTeX math, code blocks, and raw URLs.",
  "author": "Markdownviewer contributors",
  "license": "MIT",
  "homepage": "https://markdownviewer.run/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/stewart-lhc/markdownviewer.git"
  },
  "bugs": {
    "url": "https://github.com/stewart-lhc/markdownviewer/issues"
  },
  "main": "dist-electron/main.js",
  "keywords": [
    "markdown",
    "markdown-viewer",
    "markdown-preview",
    "github-flavored-markdown",
    "readme-viewer",
    "mermaid",
    "katex",
    "nextjs"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "desktop:clean": "node -e \"const fs=require('node:fs'); for (const path of ['desktop-runtime','dist-electron','release']) fs.rmSync(path,{recursive:true,force:true});\"",
    "desktop:dev": "node scripts/desktop-dev.mjs",
    "desktop:build:main": "tsc -p electron/tsconfig.json",
    "desktop:stage-next": "node scripts/desktop-stage-next.mjs",
    "desktop:dist": "npm run desktop:clean && npm run build && npm run desktop:build:main && npm run desktop:stage-next && electron-builder --win nsis --x64",
    "desktop:dist:dir": "npm run desktop:clean && npm run build && npm run desktop:build:main && npm run desktop:stage-next && electron-builder --dir"
  },
  "build": {
    "appId": "run.markdownviewer.desktop",
    "productName": "Markdownviewer",
    "executableName": "Markdownviewer",
    "files": [
      "dist-electron/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "desktop-runtime",
        "to": "desktop-runtime"
      }
    ],
    "directories": {
      "output": "release"
    },
    "win": {
      "signAndEditExecutable": false,
      "target": [
        "nsis"
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "fileAssociations": [
      {
        "ext": [
          "md",
          "markdown",
          "mdx",
          "txt"
        ],
        "name": "Markdown document",
        "role": "Editor"
      }
    ]
  },
  "dependencies": {
    "cledit": "^1.2.0",
    "katex": "^0.16.25",
    "lucide-react": "^1.17.0",
    "lz-string": "^1.5.0",
    "mermaid": "^9.1.7",
    "next": "^16.2.4",
    "prismjs": "^1.30.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-katex": "^7.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.6.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@vitejs/plugin-react": "^5.1.0",
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1",
    "jsdom": "^27.0.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
